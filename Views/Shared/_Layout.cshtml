<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portal Académico</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-light">

<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container-fluid">

            <a class="navbar-brand fw-bold" asp-controller="Cursos" asp-action="Index">
                🎓 Portal Académico
            </a>

            <div class="navbar-nav">
                <a class="nav-link text-white" asp-controller="Cursos" asp-action="Index">Cursos</a>
                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Inicio</a>
            </div>

            <div class="ms-auto">
                <partial name="_LoginPartial" />
            </div>

        </div>
    </nav>
</header>

<div class="container mt-4">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-center mt-5 py-3 bg-white">
    <div class="container">
        &copy; 2026 - Portal Académico
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>