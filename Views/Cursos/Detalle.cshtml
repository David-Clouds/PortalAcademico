@model PortalAcademico.Models.Curso

<h2>@Model.Nombre</h2>

<p><strong>Código:</strong> @Model.Codigo</p>
<p><strong>Créditos:</strong> @Model.Creditos</p>
<p><strong>Horario:</strong> @Model.HorarioInicio - @Model.HorarioFin</p>



<a href="/Cursos">Volver</a>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
<a href="/Cursos/Inscribirse/@Model.Id" class="btn btn-success">
    Inscribirse
</a>